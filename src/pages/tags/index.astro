---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Sidebar from '../../components/Sidebar.astro';
import { getAllTags, tagSlug } from '../../utils/posts';
import { url } from '../../utils/url';

const tags = await getAllTags();
---
<BaseLayout title="Topics">
  <div class="frame">
    <div class="layout">
      <Sidebar />
      <div class="content">
        <section class="intro" style="grid-template-columns: 1fr;">
          <div>
            <div class="eyebrow">Topics</div>
            <h1>Browse by topic.</h1>
            <p class="bio">Every tag currently in use.</p>
          </div>
        </section>
        <section style="padding: 2rem 0;">
          {tags.map(({ tag, count }) => (
            <a class="tag" href={url(`/tags/${tagSlug(tag)}`)}>
              {tag}<span class="count">{count}</span>
            </a>
          ))}
          {tags.length === 0 && (
            <p style="color: var(--ink-faint);">No tags yet.</p>
          )}
        </section>
      </div>
    </div>
  </div>
</BaseLayout>
