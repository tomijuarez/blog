---
import BaseLayout from '../layouts/BaseLayout.astro';
import Sidebar from '../components/Sidebar.astro';
import { SITE } from '../consts';
---
<BaseLayout title="About">
  <div class="frame">
    <div class="layout">
      <Sidebar />
      <div class="content">
        <section class="intro" style="grid-template-columns: 1fr;">
          <div>
            <div class="eyebrow">Colofón</div>
            <h1>Sobre este blog.</h1>
            <p class="bio">{SITE.authorBio}</p>
          </div>
        </section>
        <div class="prose">
          <p>
            Hecho con <a href="https://astro.build">Astro</a>, escrito en Markdown / MDX,
            con fórmulas tipografiadas con <a href="https://katex.org">KaTeX</a> y hosteado
            gratis en GitHub Pages. Las entradas viven como archivos planos en git — sin
            base de datos, sin CMS, sin servidor.
          </p>
          <p>
            Para publicar, pusheo un <code>.mdx</code> nuevo al repo; un workflow de
            GitHub Actions rebuildea y redeploya.
          </p>
          <p>
            Código: <a href={SITE.github}>{SITE.github.replace('https://', '')}</a>.
          </p>
        </div>
      </div>
    </div>
  </div>
</BaseLayout>
